<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TcpClientMelodies.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme/>
            
        <!-- Глобальный стиль: все кнопки, КРОМЕ тех, у которых есть класс pianoKey -->
        <Style Selector="Button:not(.pianoKey)">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style Selector="Button:not(.pianoKey) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="CornerRadius" Value="8" />
        </Style>

    </Application.Styles>
</Application>