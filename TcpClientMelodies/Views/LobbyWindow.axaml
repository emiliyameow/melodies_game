
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TcpClientMelodies.Views.LobbyWindow"
        Title="Музыкальная битва — Лобби"
        Width="520" Height="350"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="Лобби" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Создайте игру или введите код, чтобы присоединиться"
                       FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Основная часть: Создать / Войти -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="20">
            <!-- Левая колонка: Создать игру -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="Создать игру" FontSize="18" FontWeight="Bold"/>

                    <Button Name="CreateSessionButton"
                            Content="Создать игру"
                            FontSize="16"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="10,5"/>

                    <TextBlock Text="Код вашей игры:"
                               FontSize="14" Margin="0,10,0,0"/>

                    <TextBlock Name="SessionCodeText"
                               Text="—"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Name="HostInfoText"
                               Text="Нажмите 'Создать игру', чтобы получить код."
                               FontSize="12"
                               Foreground="Gray"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Правая колонка: Войти по коду -->
            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="Войти по коду" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="Введите код комнаты:"
                               FontSize="14"/>

                    <TextBox Name="JoinCodeTextBox"
                             Width="150"
                             HorizontalAlignment="Left"
                             FontSize="18"
                             MaxLength="8"
                             Watermark="ABCD"/>

                    <Button Name="JoinSessionButton"
                            Content="Подключиться"
                            FontSize="16"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="10,5"
                            Margin="0,5,0,0"/>

                    <TextBlock Name="JoinErrorText"
                               Text=""
                               FontSize="12"
                               Foreground="Tomato"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя строка: статус -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,10,0,0">
            <TextBlock Name="StatusText"
                       Text=""
                       FontSize="12"
                       Foreground="Gray"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
