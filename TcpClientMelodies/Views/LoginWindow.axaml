<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TcpClientMelodies.Views.LoginWindow"
        Title="Музыкальная битва"
        Width="520" Height="360"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="20">

        <!-- Верх: заголовок и пояснение -->
        <StackPanel Grid.Row="0"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock Text="Музыкальная битва"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Подключитесь к серверу, чтобы принять участие в музыкальной битве вместе с другом!"
                       FontSize="13"
                       Foreground="Gray"
                       TextAlignment="Center"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Центр: основная кнопка действия -->
        <Border Grid.Row="1"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#CCCCCC"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="12"
                        HorizontalAlignment="Center">
                
                <TextBlock Text="Подключение к серверу"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Нажмите кнопку ниже, чтобы установить соединение."
                           FontSize="12"
                           Foreground="Gray"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>

                <Button Name="ConnectButton"
                        Content="Подключиться"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="260"
                        Height="46"
                        HorizontalAlignment="Center"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="16"/>
            </StackPanel>
        </Border>

        <!-- Информация о сервере -->
        <TextBlock Grid.Row="2"
                   Text="Сервер: 127.0.0.1:8888"
                   FontSize="13"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

        <!-- Низ: статус -->
        <TextBlock Grid.Row="3"
                   Name="StatusText"
                   Text=""
                   Foreground="Red"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
