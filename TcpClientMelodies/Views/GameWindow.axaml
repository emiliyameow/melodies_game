
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TcpClientMelodies.Views.GameWindow"
        Title="Музыкальная Битва"
        Width="1000" Height="800"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Window.Styles>
        <!-- Стиль для БЕЛЫХ клавиш -->
        <Style Selector="Button.whiteKey">
            <Setter Property="Height" Value="200"/>
            <Setter Property="VerticalAlignment" Value="Top"/> <!-- Важно! -->
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="Padding" Value="0,0,0,10"/>
            <Setter Property="CornerRadius" Value="0,0,5,5"/>
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0"/> <!-- Убираем отступы, чтобы они слиплись -->
        </Style>
            
        <Style Selector="Button.whiteKey:pressed">
            <Setter Property="Background" Value="#DDDDDD"/>
        </Style>

        <!-- Стиль для ЧЕРНЫХ клавиш (декоративные) -->
        <Style Selector="Border.blackKey">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Height" Value="120"/> <!-- Короче белых -->
            <Setter Property="VerticalAlignment" Value="Top"/>
            <!-- Z-Index автоматически выше, так как они объявлены позже в XAML -->
            <Setter Property="Margin" Value="8,0"/> <!-- Отступы с боков, чтобы они были уже -->
            <Setter Property="CornerRadius" Value="0,0,3,3"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!-- Тень для объема -->
            <Setter Property="BoxShadow" Value="2 2 5 0 #88000000"/>
        </Style>
        
        <!-- стиль для раунда -->
        <Style Selector="Button.lit">
            <Setter Property="Background" Value="#FFE082"/> <!-- мяглая подсветка -->
            <Setter Property="BorderBrush" Value="#FFA000"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <!-- стиль для раунда -->
        <Style Selector="Button.lit_player">
            <Setter Property="Background" Value="#8AD2FF"/> <!-- мяглая подсветка -->
            <Setter Property="BorderBrush" Value="#869CFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
    </Window.Styles>
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <!-- 2. Панель с кнопкой задания -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Name="PlayTaskButton" 
                    Content="▶️ Воспроизвести задание" 
                    FontSize="18" FontWeight="Bold"
                    Padding="20,10"
                    Background="#FF9800" Foreground="White"/>
         
            <!-- Счетчик прослушиваний -->
            <TextBlock Name="ReplayCountText" 
                       Text="Прослушано: 0" 
                       VerticalAlignment="Center" Margin="15,0"
                       FontSize="16" Foreground="Gray"/>
        </StackPanel>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ: ИНФОРМАЦИЯ О РАУНДЕ -->
        <Border Grid.Row="0" Background="#f0f0f0" Padding="20" BorderBrush="#ccc" BorderThickness="0,0,0,1">
            <!-- Grid с 3 колонками: Лево (*), Центр (Auto), Право (*) -->
            <Grid ColumnDefinitions="*, Auto, *">
                
                <!-- Слева: Раунд -->
                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock Text="РАУНД" FontSize="14" Foreground="Gray"/>
                    <TextBlock Name="RoundText" Text="1 / 6" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
                
                <!-- Центр: Статус -->
                <TextBlock Grid.Column="1" 
                           Name="GameStatusText" 
                           Text="Ожидание соперника..." 
                           FontSize="20" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="#007ACC"/>

                <!-- Справа: Очки -->
                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock Text="БАЛЛЫ" FontSize="14" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Name="ScoreText" Text="0" FontSize="24" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ЦЕНТР: ПИАНИНО -->
        <Grid Name= "Piano" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- C -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- D -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- E -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- F -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- G -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- A -->
                <ColumnDefinition Width="50"/> <ColumnDefinition Width="50"/> <!-- B -->
            </Grid.ColumnDefinitions>

            <!-- Белые клавиши -->
            <Button Name="C" Grid.Column="0" Grid.ColumnSpan="2" Content="C" Classes="whiteKey pianoKey"/>
            <Button Name="D" Grid.Column="2" Grid.ColumnSpan="2" Content="D" Classes="whiteKey pianoKey"/>
            <Button Name="E" Grid.Column="4" Grid.ColumnSpan="2" Content="E" Classes="whiteKey pianoKey"/>
            <Button Name="F" Grid.Column="6" Grid.ColumnSpan="2" Content="F" Classes="whiteKey pianoKey"/>
            <Button Name="G" Grid.Column="8" Grid.ColumnSpan="2" Content="G" Classes="whiteKey pianoKey"/>
            <Button Name="A" Grid.Column="10" Grid.ColumnSpan="2" Content="A" Classes="whiteKey pianoKey"/>
            <Button Name="B" Grid.Column="12" Grid.ColumnSpan="2" Content="B" Classes="whiteKey pianoKey"/>

            <!-- Черные клавиши (Декорация) -->
            <Border Grid.Column="1" Grid.ColumnSpan="2" Classes="blackKey pianoKey"/>
            <Border Grid.Column="3" Grid.ColumnSpan="2" Classes="blackKey pianoKey"/>
            <Border Grid.Column="7" Grid.ColumnSpan="2" Classes="blackKey pianoKey"/>
            <Border Grid.Column="9" Grid.ColumnSpan="2" Classes="blackKey pianoKey"/>
            <Border Grid.Column="11" Grid.ColumnSpan="2" Classes="blackKey pianoKey"/>
        </Grid>

        <!-- НИЗ: ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <StackPanel Grid.Row="3" Margin="20" Spacing="10">
            
            <TextBlock Name="LogText" Height="30" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>

                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                
                
                <!-- 3. Кнопка "Начать запись" (Появляется после прослушивания) -->
                <Button Name="StartRecordingButton" 
                        Content="Начать запись" 
                        Background="#D32F2F" Foreground="White"
                        FontSize="16" Padding="15,10" Margin="5"
                        IsVisible="False"/>

                <!-- 4. Кнопки управления ЗАПИСЬЮ (Видны только во время записи) -->
                <StackPanel Name="RecordingControlsPanel" Orientation="Horizontal" IsVisible="False">
                    <Button Name="ClearButton" 
                            Content="Сброс" 
                            Background="Gray" Foreground="White" 
                            FontSize="16" Padding="15,10" Margin="5"/>
                    
                    <Button Name="ListenRecordingButton" 
                            Content="Воспроизвести ответ" 
                            Background="#007ACC" Foreground="White" 
                            FontSize="16" Padding="15,10" Margin="5"/>
                    
                    <Button Name="SendButton" 
                            Content="ОТПРАВИТЬ" 
                            Background="Green" Foreground="White" 
                            FontSize="16" Padding="15,10" Margin="5"/>
                </StackPanel>
            </WrapPanel>

        </StackPanel>

    </Grid>
</Window>
